{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "dext-orchestrator",
  "agent": {
    "dext-orchestrator": {
      "model": "deepseek/deepseek-v4-flash",
      "thinking": {"type": "enabled"},
      "reasoning_effort": "high"
    },
    "dext-tester": {
      "model": "deepseek/deepseek-v4-flash",
      "thinking": {"type": "disabled"},
      "temperature": 0.2
    },
    "dext-developer": {
      "model": "deepseek/deepseek-v4-flash",
      "thinking": {"type": "disabled"},
      "temperature": 0.4
    },
    "dext-reviewer": {
      "model": "deepseek/deepseek-v4-flash",
      "thinking": {"type": "enabled"},
      "reasoning_effort": "max"
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp/oauth",
      "enabled": true
    },
    "obsidian": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@bitbonsai/mcpvault@latest",
        "/home/dext/dext-brain"
      ]
    }
  },
  "autoupdate": true
}